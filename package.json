{
  "name": "claude-harness-eng-v5",
  "version": "2.1.0",
  "private": true,
  "description": "Claude Code plugin scaffold for autonomous long-running application development.",
  "scripts": {
    "certification": "node .claude/scripts/certification-report.js",
    "status": "node .claude/scripts/pipeline-status.js",
    "drift": "node .claude/scripts/drift-report.js",
    "flakes": "node .claude/scripts/flake-detector.js",
    "flakes:e2e": "node .claude/scripts/flake-detector.js --e2e",
    "harness-coverage": "node .claude/scripts/harness-coverage.js",
    "agent-readiness": "node .claude/scripts/agent-readiness.js",
    "agent-readiness:assert": "node .claude/scripts/assert-readiness-ratchet.js",
    "agent-readiness:baseline": "node .claude/scripts/update-readiness-baseline.js",
    "retention": "node .claude/scripts/runs-retention.js",
    "retention:dry": "node .claude/scripts/runs-retention.js --dry-run",
    "package:skus": "node .claude/scripts/package-sku.js all --clean",
    "package:core": "node .claude/scripts/package-sku.js core --clean",
    "package:lite": "node .claude/scripts/package-sku.js lite --clean",
    "release:skus": "node .claude/scripts/release-skus.js",
    "scaffold:upgrade": "node .claude/scripts/scaffold-upgrade.js",
    "slo": "node .claude/scripts/slo-check.js",
    "canvas-sync": "node .claude/scripts/canvas-sync-check.js",
    "sensor-waivers": "node .claude/scripts/validate-sensor-waivers.js",
    "deep-mutation": "node .claude/scripts/deep-mutation.js",
    "mutation": "node .claude/scripts/mutation-gate.js --staged",
    "test-deletion-gate": "node .claude/scripts/test-deletion-gate.js --staged",
    "cycles": "node .claude/scripts/cycle-gate.js",
    "coupling-gate": "node .claude/scripts/coupling-gate.js",
    "approved-fixtures": "node .claude/scripts/approved-fixtures-gate.js",
    "approve-fixtures": "node .claude/scripts/approve-fixtures.js",
    "flake-history": "node .claude/scripts/flake-history.js",
    "contract-drift": "node .claude/scripts/contract-drift-gate.js",
    "regression-gate": "node .claude/scripts/regression-gate.js",
    "impact-scope": "node .claude/scripts/impact-scope.js",
    "local-regression-gate": "node .claude/scripts/local-regression-gate.js",
    "lint": "eslint .claude/hooks .claude/scripts .claude/git-hooks test eslint.config.js",
    "test": "node --test test/*.test.js test/e2e/helpers/*.test.js",
    "build:chain": "node .claude/scripts/build-chain.js",
    "test:e2e": "node test/e2e/run-pack.js cert",
    "test:e2e:fast": "node test/e2e/run-pack.js fast",
    "test:e2e:smoke": "node test/e2e/run-pack.js smoke",
    "test:e2e:live": "node test/e2e/run-pack.js live",
    "test:e2e:cert": "node test/e2e/run-pack.js cert",
    "test:e2e:all": "node test/e2e/run-pack.js all",
    "test:smoke": "node test/e2e/run-pack.js smoke",
    "test:plan": "node test/e2e/run-pack.js live --only plan",
    "test:auto": "node test/e2e/run-pack.js live --only auto",
    "test:full-auto": "node test/e2e/run-pack.js live --only full-auto",
    "test:gated": "node test/e2e/run-pack.js live --only gated",
    "test:feature": "node test/e2e/run-pack.js live --only feature",
    "test:routes": "node test/e2e/run-pack.js live --only auto,full-auto,gated,feature",
    "test:semi": "node test/e2e/run-pack.js live --only semi",
    "install:browser": "playwright install chromium",
    "test:evals": "node test/evals/run-evals.js",
    "test:all": "node --test --test-force-exit test/*.test.js test/e2e/helpers/*.test.js",
    "test:symphony": "cd symphony_clone && npm ci --silent && npm test"
  },
  "devDependencies": {
    "eslint": "^9.28.0",
    "globals": "^16.2.0",
    "playwright": "^1.48.0"
  }
}
