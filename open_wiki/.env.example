# Keep the actual key in your shell, CI secret store, or an untracked .env file.
OPENWIKI_PROVIDER=openai
OPENAI_API_KEY=
OPENWIKI_MODEL_ID=gpt-5.6-terra

# Optional Moonshot alternative:
# OPENWIKI_PROVIDER=moonshot
# MOONSHOT_API_KEY=
# MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
# MOONSHOT_MODEL_ID=kimi-k3

# OpenWiki sends anonymous reliability telemetry by default. This package disables it.
OPENWIKI_TELEMETRY_DISABLED=1
