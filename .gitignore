.claude/scheduled_tasks.lock
.claude/tdd-guard/
node_modules/
dist/
# Generated SKU trees (npm run package:skus); source of truth remains .claude/ + harness-lite/
dist/skus/
# specs/ is pipeline runtime output, not part of the base scaffold — /scaffold only
# creates empty subfolders; content is produced by running the pipeline against a
# project. This repo dogfoods /code-map + /brownfield against itself (Project Zero)
# but that output is local/regenerable, not shipped scaffold content. Exception: the
# committed DeepWiki under specs/brownfield (its wiki subdirectory) ships in the same
# PR as the code it documents — see code-map/SKILL.md and feature-wiki-committed-contract.test.js.
/specs/*
!/specs/brownfield/
/specs/brownfield/*
!/specs/brownfield/wiki/
# Local toolchain installs (gitleaks etc.) — CI installs its own copies
.tools/
build/
packages/harness-core/
packages/harness-lite/
packages/harness-full/
!.claude/skills/build/
.next/
.venv/
venv/
__pycache__/
*.pyc
.DS_Store
.env
.env.local
.env.*.local
.symphony/
symphony_clone/.symphony/
symphony_clone/workspaces/
symphony_clone/logs/
*.jsonl
# .claude/state/ is a tracked harness snapshot (learned rules, failures, iteration
# log, coverage baseline). Only runtime churn stays out: telemetry-ledger.jsonl and
# the live pending-reviews.jsonl are already covered by *.jsonl above; also exclude
# logs, log offsets, transient counters, and archived state.
.claude/state/archive/
.claude/state/*.log
.claude/state/*.offset
.claude/state/*.lock
.claude/state/review-block-count
.claude/state/auto-continue-count
.claude/state/auto-continue-progress
.claude/state/inflight-agents.json
# Local regenerate receipt for docs/CODEBASE.md (product is the md file)
.claude/state/human-codebase.json
# Navigation indexes (regenerated by graph-refresh / nav-query refresh)
.claude/state/nav-index/
.claude/state/nav-graph-index.json
.claude/state/context-pack-last.json
.claude/state/nav-telemetry-summary.json
# Token-governor compact-runner caches (run-compact.js) — transient
.claude/state/context-cache/
.claude/state/tool-output/
!.claude/templates/state-seeds/pending-reviews.jsonl
test/e2e/results/*
!test/e2e/results/.gitkeep
test/e2e/output/
.playwright-mcp/
# e2e self-test harness live-run output (smoke/plan/auto/semi-auto generate these)
test/e2e/smoke-output/
test/e2e/plan-output/
test/e2e/auto-output/
test/e2e/semi-auto-output/
test/e2e/full-auto-output/
test/e2e/feature-output/
test/e2e/gated-build-output/
test/e2e/vibe-output/
test/e2e/brownfield-run-output/
test/e2e/screenshots/
# Runtime output: review/eval agents (clean-code, security, diff) write reports + verdict
# JSON here each run; the pre-commit gate reads them. Regenerated every time, never shipped.
**/specs/reviews/
# Superpowers SDD execution scratch (task briefs/reports, progress, review diffs)
# generated while implementing a plan. The durable design lives in docs/superpowers/.
.superpowers/
