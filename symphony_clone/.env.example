TRACKER_PROVIDER=linear
LINEAR_API_KEY=lin_replace_me
LINEAR_PROJECT_SLUG=replace-with-linear-project-slug
TARGET_REPO_URL=git@github.com:your-org/your-repo.git
WORKSPACE_ROOT=/workspaces

READY_STATE=Ready for Agent
RUNNING_STATE=In Progress
REVIEW_STATE=Human Review
BLOCKED_STATE=Blocked
REVIEW_STATE_CANDIDATES=Human Review,In Review,Review
BLOCKED_STATE_CANDIDATES=Blocked,Canceled,Cancelled
READY_LABEL=agent-ready
# Planning (architect stage): an issue in READY_STATE carrying PLAN_LABEL is a PRD.
# Claiming it runs /brd -> /spec -> /design -> /test -> /tracker-publish (plan only,
# no app code), which publishes the per-cluster group issues the execution path
# then claims. The PRD issue advances to PLANNED_STATE. The PRD is the issue
# description (or a repo file it names).
PLAN_LABEL=agent-plan
PLANNED_STATE=Planned
PLANNED_STATE_CANDIDATES=Planned,Ready for Agent
TERMINAL_STATES=Done,Closed,Canceled,Cancelled,Duplicate
MAX_CONCURRENT_RUNS=1
POLL_INTERVAL_MS=60000
MAX_RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=60000
RETRY_MAX_DELAY_MS=900000
# Hard ceiling on wall-clock time per Claude run (ms). When exceeded, the
# subprocess is SIGTERM'd and the issue follows the normal retry/blocked
# path. Default 7200000 (2h). Legacy alias: CLAUDE_TURN_TIMEOUT_MS.
MAX_WALLCLOCK_PER_RUN_MS=7200000
# delete | keep. "delete" removes /workspaces/<key> after a terminal state
# (human_review or final blocked) to free disk. Set "keep" for forensics.
WORKSPACE_RETENTION=delete
STATE_DIR=/workspaces/.symphony
LOG_ROOT=/workspaces/.symphony/logs
STATUS_PORT=0
CLAUDE_COMMAND=claude --print --permission-mode bypassPermissions
# Slash-command Claude is told to execute. Placeholders: {{group}}, {{issue}}.
# Per-issue override: add a Linear label like "mode-lite" or "mode-deep".
HARNESS_COMMAND_TEMPLATE=/auto --group {{group}}

GITHUB_BASE_BRANCH=main
BRANCH_PREFIX=agent
CREATE_PR=true
GITHUB_TOKEN=

# Auto-merge (the "no human" step). When AUTO_MERGE=true, a run that reaches
# human_review (harness gates already passed) enables GitHub NATIVE auto-merge on
# its PR — GitHub merges it only once required status checks pass and branch
# protections are satisfied, so a red build never lands — and the issue advances
# to DONE_STATE instead of REVIEW_STATE. Off by default (stops at Human Review).
# Requires "Allow auto-merge" enabled on the GitHub repo. If enabling fails, the
# run falls back to human review rather than dropping the PR.
AUTO_MERGE=false
MERGE_METHOD=merge
DONE_STATE=Done
DONE_STATE_CANDIDATES=Done,Merged,Closed
