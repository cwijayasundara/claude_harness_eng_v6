{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claude Harness Sensor Waivers",
  "type": "object",
  "additionalProperties": false,
  "required": ["waivers"],
  "properties": {
    "waivers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sensor_id", "scope", "reason", "expires", "approved_by"],
        "properties": {
          "sensor_id": { "type": "string", "minLength": 1 },
          "scope": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 12 },
          "expires": { "type": "string", "minLength": 1 },
          "approved_by": { "type": "string", "minLength": 1 },
          "created_at": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
