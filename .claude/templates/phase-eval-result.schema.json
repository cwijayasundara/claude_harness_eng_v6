{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "phase-eval-result.schema.json",
  "title": "Phase Evaluation Result",
  "description": "Schema for phase ratchet evaluator output used by the Claude Harness Engine v4 GAN loop",
  "type": "object",
  "required": [
    "phase",
    "iteration",
    "timestamp",
    "scores",
    "weighted_average",
    "threshold",
    "per_criterion_minimum",
    "verdict",
    "failing_criteria",
    "findings",
    "traceability_report",
    "score_history"
  ],
  "properties": {
    "phase": {
      "type": "string",
      "enum": ["brd", "spec", "design", "brownfield", "seam", "deploy"],
      "description": "The planning phase that was evaluated"
    },
    "iteration": {
      "type": "integer",
      "minimum": 1,
      "description": "Current evaluation iteration (1-based)"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the evaluation"
    },
    "scores": {
      "type": "object",
      "description": "Scores for each rubric criterion (1-10 integer scale)",
      "required": [
        "completeness",
        "traceability",
        "specificity",
        "consistency",
        "actionability"
      ],
      "properties": {
        "completeness": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "traceability": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "specificity": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "consistency": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "actionability": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        }
      },
      "additionalProperties": false
    },
    "weighted_average": {
      "type": "number",
      "minimum": 1,
      "maximum": 10,
      "description": "Weighted average across all criteria (1-10 scale)"
    },
    "threshold": {
      "type": "number",
      "description": "Minimum weighted average required to PASS"
    },
    "per_criterion_minimum": {
      "type": "integer",
      "description": "Minimum score any single criterion must meet to avoid FAIL"
    },
    "verdict": {
      "type": "string",
      "enum": ["PASS", "FAIL"],
      "description": "Overall evaluation verdict"
    },
    "failing_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of criterion names that fell below per_criterion_minimum or caused FAIL"
    },
    "findings": {
      "type": "array",
      "description": "Detailed findings from the evaluation",
      "items": {
        "type": "object",
        "required": ["criterion", "severity", "location", "finding", "suggestion"],
        "properties": {
          "criterion": {
            "type": "string",
            "enum": ["completeness", "traceability", "specificity", "consistency", "actionability"],
            "description": "Which rubric criterion this finding relates to"
          },
          "severity": {
            "type": "string",
            "enum": ["error", "warning", "info"],
            "description": "Severity level of the finding"
          },
          "location": {
            "type": "string",
            "description": "File path, section, or artifact where the issue was found"
          },
          "finding": {
            "type": "string",
            "description": "Description of what was found"
          },
          "suggestion": {
            "type": "string",
            "description": "Actionable suggestion to resolve the finding"
          }
        },
        "additionalProperties": false
      }
    },
    "traceability_report": {
      "type": "object",
      "description": "Summary of upstream-to-downstream traceability coverage",
      "properties": {
        "upstream_items": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of upstream items expected to be covered"
        },
        "covered": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of upstream items with downstream coverage"
        },
        "orphans": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of downstream items with no upstream linkage"
        },
        "coverage_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Traceability coverage percentage"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "upstream_id": { "type": "string" },
              "downstream_ids": {
                "type": "array",
                "items": { "type": "string" }
              },
              "status": {
                "type": "string",
                "enum": ["covered", "missing", "orphan"]
              }
            },
            "additionalProperties": false
          },
          "description": "Per-item traceability mapping"
        }
      },
      "additionalProperties": false
    },
    "score_history": {
      "type": "array",
      "description": "Score progression across iterations for ratchet tracking",
      "items": {
        "type": "object",
        "required": ["iteration", "weighted_average", "verdict"],
        "properties": {
          "iteration": {
            "type": "integer",
            "minimum": 1
          },
          "weighted_average": {
            "type": "number",
            "minimum": 1,
            "maximum": 10
          },
          "verdict": {
            "type": "string",
            "enum": ["PASS", "FAIL"]
          }
        },
        "additionalProperties": false
      }
    },
    "upstream_phase": {
      "type": ["string", "null"],
      "description": "Name of the upstream phase that produced the input artifact, or null if none"
    },
    "upstream_artifact": {
      "type": ["string", "null"],
      "description": "Path to the upstream artifact that was evaluated against, or null if none"
    }
  },
  "additionalProperties": false
}
