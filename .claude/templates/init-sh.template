#!/bin/bash
set -euo pipefail

echo "=== Bootstrapping dev environment ==="

# Backend dependencies
{{BACKEND_INSTALL}}

# Frontend dependencies
{{FRONTEND_INSTALL}}

# Environment
if [ -f ".env.example" ] && [ ! -f ".env" ]; then
  cp .env.example .env
  echo "Created .env from .env.example — add your API keys"
fi

# Docker services
{{DOCKER_COMPOSE_CMD}}

# Telemetry stack (OTEL Collector + Prometheus + Pushgateway + Grafana)
if [ -f "telemetry_docker_compose.yml" ]; then
  echo "Starting telemetry stack..."
  docker compose -f telemetry_docker_compose.yml up -d
  echo "Grafana dashboard: http://localhost:3001/d/claude-harness-overview/"
fi

# Health checks
echo "Waiting for services..."
{{HEALTH_CHECKS}}

echo "=== Environment ready ==="
