#!/usr/bin/env node

'use strict';

// Git pre-commit hook — the commit-time quality gate.
// Replaces the PostToolUse(Bash) trio (pre-commit-gate, coverage-gate,
// sprint-contract-gate): a real git hook blocks the commit BEFORE it exists,
// fires exactly once per commit however it was invoked, and cannot be fooled
// by `--amend` or unrelated commands containing "git commit".
// Gates, cheapest first: staged-file layer check → sprint contract →
// project-wide tsc (TS) → pytest coverage ratchet (Python).
// All toolchain gates fail open when unprovisioned. HARNESS_COVERAGE_GATE=off
// skips coverage. Runs from the repo root (git guarantees cwd).

const fs = require('fs');
const path = require('path');
const { execFileSync } = require('child_process');
const { checkContentViolations, loadLayerConfig, getLayer } = require(path.join(__dirname, '..', 'hooks', 'lib', 'layers'));
const { run, output, shouldBlock, skipped } = require(path.join(__dirname, '..', 'hooks', 'lib', 'toolchain'));
const { findImpureFiles } = require(path.join(__dirname, 'lib', 'refactor-purity'));
const { validate: validateSchema } = require(path.join(__dirname, '..', 'hooks', 'lib', 'contract-schema'));
const { baselineSecretFindings } = require(path.join(__dirname, '..', 'hooks', 'lib', 'security-scan'));
const { secretScanExempt } = require(path.join(__dirname, '..', 'hooks', 'lib', 'secrets'));

const SOURCE_EXTS = new Set(['.py', '.ts', '.tsx', '.js', '.jsx', '.mjs', '.cjs']);
const FLOOR = 80;

function fail(message) {
  process.stdout.write(message);
  process.stderr.write(message);
  process.exit(1);
}

// A gate that should have run but failed open (missing/unprovisioned toolchain)
// is announced, not swallowed — otherwise "skipped" is indistinguishable from
// "passed" and unverified code commits looking green. Advisory only: never exits.
function noteSkip(gate, reason) {
  process.stdout.write(
    `WARNING: GATE SKIPPED — ${gate} did not run (${reason}). Staged code was NOT verified by this gate.\n` +
      `         Fix: provision the toolchain, or set the matching *_GATE=off to acknowledge the skip.\n`
  );
}

function stagedFiles() {
  const out = execFileSync('git', ['diff', '--cached', '--name-only', '--diff-filter=ACMR'], {
    encoding: 'utf8',
  });
  return out.split('\n').filter(Boolean);
}

// Computational secrets sensor (gap G3), always-available baseline tier: regex
// scan over staged file contents. Runs on ALL staged files (not just source —
// credentials hide in config/yaml too), minus the same exemptions the pre-write
// gate honors (.md, .env.example, harness fixture dirs). gitleaks is the
// enhanced tier, run at /gate via security-scan.js where it can be provisioned.
function checkSecrets(projectDir, staged) {
  const targets = staged.filter((f) => !secretScanExempt(f, projectDir));
  const findings = baselineSecretFindings(targets, (f) => fs.readFileSync(path.join(projectDir, f), 'utf8'));
  if (findings.length === 0) return;
  const lines = findings.map((x) => `  ${x.file} — ${x.message}`);
  fail(
    `BLOCKED: potential secrets in staged files:\n${lines.join('\n')}\n` +
    'Fix: move the secret to .env (gitignored) and reference it via an env var; never commit credentials. ' +
    'If this is a non-secret fixture, place it under an exempt path or rename it.\n'
  );
}

function checkLayers(projectDir, stagedSource) {
  const layerCfg = loadLayerConfig(projectDir);
  const violations = [];
  let mapped = 0;
  for (const file of stagedSource) {
    if (getLayer(file, layerCfg) !== null) mapped++;
    let content;
    try {
      content = fs.readFileSync(file, 'utf8');
    } catch (_) {
      continue;
    }
    violations.push(...checkContentViolations(file, content, layerCfg));
  }
  if (violations.length > 0) {
    const lines = violations.map((v) => `  ${v.filePath}:${v.line} — ${v.layer} cannot import from ${v.imported}`);
    fail(`BLOCKED: Architecture violations found — fix before committing:\n${lines.join('\n')}\nFix: Move imports to the correct layer or extract shared types to src/types/.\n`);
  }
  // No silent no-op: if the layer gate matched nothing it is not protecting
  // this project — say so (advisory, never blocks).
  if (mapped === 0 && stagedSource.length > 0) {
    process.stdout.write(
      `note: layer gate matched no staged file — this project's layout does not follow ` +
      `${layerCfg.roots.join('|')}/<layer>/. Configure "architecture": {"layers": [...], "layer_roots": [...]} ` +
      `in project-manifest.json if it should be layer-checked.\n`
    );
  }
}

// keeping-refactors-pure: a refactor commit changes no behavior, so it may not
// touch tests or snapshots. The skill sets HARNESS_COMMIT_KIND=refactor on the
// commit command; without it this gate is inert. The commit-msg hook covers the
// case where the subject line starts with refactor:/cleanup:/etc. and the env
// var was not set (bare `git commit -m "refactor: ..."`).
function checkRefactorPurity(staged) {
  if (process.env.HARNESS_COMMIT_KIND !== 'refactor') return;
  const impure = findImpureFiles(staged);
  if (impure.length === 0) return;
  fail(
    'BLOCKED: refactor commit touches test/snapshot files:\n' +
    impure.map((f) => `  ${f}`).join('\n') +
    '\nFix: a refactor commit changes no behavior — tests and snapshots must stay ' +
    'byte-identical. Split the behavioral work into its own commit ' +
    '(see .claude/skills/keeping-refactors-pure/SKILL.md).\n'
  );
}

// The contract file must BE a contract: a malformed one would make /evaluate
// fail confusingly later (or vacuously pass). Validation is skipped without
// noise only when the schema file itself is absent (unscaffolded project).
function validateContractShape(projectDir, group) {
  const schemaPath = path.join(projectDir, '.claude', 'skills', 'evaluate', 'references', 'contract-schema.json');
  if (!fs.existsSync(schemaPath)) return;
  let contract;
  try {
    contract = JSON.parse(fs.readFileSync(path.join(projectDir, 'sprint-contracts', `${group}.json`), 'utf8'));
  } catch (_) {
    fail(`BLOCKED: sprint-contracts/${group}.json is not valid JSON.\nFix: re-negotiate the contract (node .claude/scripts/validate-contract.js sprint-contracts/${group}.json to check).\n`);
  }
  const errors = validateSchema(JSON.parse(fs.readFileSync(schemaPath, 'utf8')), contract);
  if (errors.length > 0) {
    fail(
      `BLOCKED: sprint-contracts/${group}.json fails schema validation:\n` +
      errors.map((e) => `  - ${e}`).join('\n') +
      `\nFix: correct the contract (node .claude/scripts/validate-contract.js sprint-contracts/${group}.json).\n`
    );
  }
}

// The evaluator-report regex alone is forgeable prose; the security verdict is
// a structured artifact the security-reviewer writes. Require both.
function checkSecurityVerdict(projectDir, group) {
  let verdict = null;
  try {
    verdict = JSON.parse(fs.readFileSync(path.join(projectDir, 'specs', 'reviews', 'security-verdict.json'), 'utf8'));
  } catch (_) {
    /* missing or unparseable = not PASS */
  }
  const passed = verdict && (verdict.pass === true || verdict.verdict === 'PASS');
  if (!passed) {
    fail(`BLOCKED: security gate for group ${group} not satisfied — specs/reviews/security-verdict.json is missing or not PASS.\nFix: run /evaluate (its security layer writes the verdict), address findings, then retry the commit.\n`);
  }
}

function checkSprintContract(projectDir) {
  let progress;
  try {
    progress = fs.readFileSync(path.join(projectDir, 'claude-progress.txt'), 'utf8');
  } catch (_) {
    return;
  }
  const groupMatch = progress.match(/^current_group:\s*(.+)$/m);
  if (!groupMatch || !groupMatch[1].trim()) return;
  const group = groupMatch[1].trim();
  if (!fs.existsSync(path.join(projectDir, 'sprint-contracts', `${group}.json`))) return;

  validateContractShape(projectDir, group);

  let report = '';
  try {
    report = fs.readFileSync(path.join(projectDir, 'specs', 'reviews', 'evaluator-report.md'), 'utf8');
  } catch (_) {
    /* missing report = not PASS */
  }
  if (!/^VERDICT:\s*PASS\s*$/m.test(report)) {
    fail(`BLOCKED: Sprint contract for group ${group} not satisfied. Run /evaluate first.\nFix: Run /evaluate to verify the sprint contract, then retry the commit.\n`);
  }
  checkSecurityVerdict(projectDir, group);
}

function checkTypescript(projectDir, stagedTs) {
  if (stagedTs.length === 0) return;
  if (!fs.existsSync(path.join(projectDir, 'tsconfig.json'))) return;
  const res = run(['npx', '--no-install', 'tsc', '--noEmit'], projectDir, 120000);
  if (shouldBlock(res)) {
    fail(`BLOCKED: type errors in the project:\n${output(res)}\nFix: resolve the type errors above before committing.\n`);
  } else if (skipped(res)) {
    noteSkip('TypeScript typecheck (tsc --noEmit)', 'tsc unavailable or unprovisioned');
  }
}

function readBaseline(projectDir, key) {
  const file = key === 'js'
    ? path.join(projectDir, '.claude', 'state', 'coverage-baseline-js.txt')
    : path.join(projectDir, '.claude', 'state', 'coverage-baseline.txt');
  try {
    const n = parseFloat(fs.readFileSync(file, 'utf8').trim());
    return Number.isFinite(n) ? n : null;
  } catch (_) {
    return null;
  }
}

function writeBaseline(projectDir, key, pct) {
  const file = key === 'js'
    ? path.join(projectDir, '.claude', 'state', 'coverage-baseline-js.txt')
    : path.join(projectDir, '.claude', 'state', 'coverage-baseline.txt');
  try {
    fs.writeFileSync(file, `${pct}\n`);
  } catch (_) {
    /* best effort */
  }
}

function checkCoverage(projectDir, stagedPy) {
  if ((process.env.HARNESS_COVERAGE_GATE || '').toLowerCase() === 'off') return;
  if (stagedPy.length === 0) return;
  if (!fs.existsSync(path.join(projectDir, 'src')) || !fs.existsSync(path.join(projectDir, 'tests'))) return;

  const res = run(['uv', 'run', 'pytest', '--cov=src', '--cov-report=term-missing', '-q'], projectDir, 110000);
  if (skipped(res)) { noteSkip('Python coverage ratchet', 'pytest/uv unavailable, timed out, or unprovisioned'); return; }
  const out = output(res);
  const match = out.match(/^TOTAL\s+.*?(\d+(?:\.\d+)?)%/m);
  if (!match) { noteSkip('Python coverage ratchet', 'could not parse pytest --cov output'); return; }
  const pct = parseFloat(match[1]);

  const baseline = readBaseline(projectDir, 'py');
  const required = baseline !== null ? baseline : FLOOR;
  if (pct < required) {
    const label = baseline !== null ? `baseline ${baseline}%` : `floor ${FLOOR}%`;
    fail(`BLOCKED: coverage ${pct}% is below the ${label}.\nFix: add tests to restore coverage before committing. The ratchet only moves forward.\n`);
  }
  if (baseline === null || pct > baseline) {
    writeBaseline(projectDir, 'py', pct);
  }
}

// JS/TS coverage constants — vitest table format differs from jest.
const VITEST_TOTAL_RE = /^All files\s*\|\s*[\d.]+\s*\|\s*[\d.]+\s*\|\s*[\d.]+\s*\|\s*([\d.]+)/m;
const JEST_TOTAL_RE = /^All files\s*\|\s*([\d.]+)/m;

function detectJsRunner(projectDir) {
  const VITEST_CONFIGS = ['vitest.config.ts', 'vitest.config.js', 'vitest.config.mjs'];
  const JEST_CONFIGS = ['jest.config.js', 'jest.config.ts', 'jest.config.mjs', 'jest.config.cjs'];
  for (const f of VITEST_CONFIGS) {
    if (fs.existsSync(path.join(projectDir, f))) return 'vitest';
  }
  // vitest can also be configured inside package.json
  try {
    const pkg = JSON.parse(fs.readFileSync(path.join(projectDir, 'package.json'), 'utf8'));
    if (pkg.vitest || (pkg.scripts && JSON.stringify(pkg.scripts).includes('vitest'))) return 'vitest';
  } catch (_) { /* ignore */ }
  for (const f of JEST_CONFIGS) {
    if (fs.existsSync(path.join(projectDir, f))) return 'jest';
  }
  try {
    const pkg = JSON.parse(fs.readFileSync(path.join(projectDir, 'package.json'), 'utf8'));
    if (pkg.jest || (pkg.scripts && JSON.stringify(pkg.scripts).includes('jest'))) return 'jest';
  } catch (_) { /* ignore */ }
  return null;
}

const JS_TEST_RE = /\.(test|spec)\.[cm]?[jt]sx?$/;
const JS_TEST_DIR_RE = /(^|\/)__tests__\/|(^|\/)tests?\//;

function checkCoverageJs(projectDir, stagedJs) {
  if ((process.env.HARNESS_COVERAGE_GATE || '').toLowerCase() === 'off') return;
  // Only staged production JS/TS files trigger the gate (not test files).
  const prodJs = stagedJs.filter((f) => !JS_TEST_RE.test(f) && !JS_TEST_DIR_RE.test(f));
  if (prodJs.length === 0) return;

  const runner = detectJsRunner(projectDir);
  if (!runner) return; // no JS test runner configured → skip

  let res;
  if (runner === 'vitest') {
    res = run(['npx', '--no-install', 'vitest', 'run', '--coverage'], projectDir, 110000);
  } else {
    res = run(['npx', '--no-install', 'jest', '--coverage', '--passWithNoTests', '--silent'], projectDir, 110000);
  }
  if (skipped(res)) { noteSkip(`JS/TS coverage ratchet (${runner})`, 'runner unavailable, timed out, or unprovisioned'); return; }
  const out = output(res);

  const re = runner === 'vitest' ? VITEST_TOTAL_RE : JEST_TOTAL_RE;
  const match = out.match(re);
  if (!match) { noteSkip(`JS/TS coverage ratchet (${runner})`, 'could not parse coverage table'); return; }

  const pct = parseFloat(match[1]);
  const baseline = readBaseline(projectDir, 'js');
  const required = baseline !== null ? baseline : FLOOR;
  if (pct < required) {
    const label = baseline !== null ? `baseline ${baseline}%` : `floor ${FLOOR}%`;
    fail(`BLOCKED: JS/TS coverage ${pct}% is below the ${label}.\nFix: add tests to restore coverage before committing. The ratchet only moves forward.\n`);
  }
  if (baseline === null || pct > baseline) {
    writeBaseline(projectDir, 'js', pct);
  }
}

try {
  const projectDir = process.cwd();
  const staged = stagedFiles();
  checkSecrets(projectDir, staged); // before the source-only exit: secrets hide in config/yaml too
  const stagedSource = staged.filter((f) => SOURCE_EXTS.has(path.extname(f).toLowerCase()));
  if (stagedSource.length === 0) process.exit(0); // docs-only commit: nothing else to gate

  const stagedPy = stagedSource.filter((f) => f.endsWith('.py'));
  const stagedTs = stagedSource.filter((f) => f.endsWith('.ts') || f.endsWith('.tsx'));
  const stagedJs = stagedSource.filter((f) => {
    const e = path.extname(f).toLowerCase();
    return e === '.js' || e === '.jsx' || e === '.mjs' || e === '.cjs' || e === '.ts' || e === '.tsx';
  });

  checkRefactorPurity(staged);
  checkLayers(projectDir, stagedSource);
  checkSprintContract(projectDir);
  checkTypescript(projectDir, stagedTs);
  checkCoverage(projectDir, stagedPy);
  checkCoverageJs(projectDir, stagedJs);
} catch (err) {
  // A broken gate must not brick committing — but it must never fail open
  // silently either: a disabled gate is indistinguishable from a passing one.
  const detail = err && err.message ? err.message : String(err);
  process.stderr.write(
    `WARNING: pre-commit quality gates crashed and were SKIPPED — this commit is NOT gated.\n` +
    `  ${detail}\n` +
    `  Details recorded in .claude/state/hook-errors.log\n`
  );
  try {
    fs.appendFileSync(
      path.join(process.cwd(), '.claude', 'state', 'hook-errors.log'),
      `${new Date().toISOString()} pre-commit: ${detail}\n`
    );
  } catch (_) {
    /* ignore */
  }
}

process.exit(0);
