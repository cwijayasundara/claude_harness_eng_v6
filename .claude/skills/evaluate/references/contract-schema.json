{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SprintContract",
  "description": "Schema for a sprint evaluation contract",
  "type": "object",
  "required": ["group", "stories", "features", "contract"],
  "additionalProperties": false,
  "properties": {
    "group": {
      "type": "string",
      "description": "Feature group or sprint identifier"
    },
    "stories": {
      "type": "array",
      "description": "User story IDs delivered in this sprint",
      "items": { "type": "string" },
      "minItems": 1
    },
    "features": {
      "type": "array",
      "description": "Feature IDs from features.json that this group satisfies. Used by evaluator to update features.json pass/fail state.",
      "items": { "type": "string" },
      "minItems": 1
    },
    "contract": {
      "type": "object",
      "description": "Verification checklist for the sprint",
      "additionalProperties": false,
      "properties": {
        "api_checks": {
          "type": "array",
          "description": "HTTP endpoint verifications",
          "items": {
            "type": "object",
            "required": ["id", "method", "path", "expected_status"],
            "properties": {
              "id": { "type": "string" },
              "method": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
              "path": { "type": "string" },
              "headers": { "type": "object", "additionalProperties": { "type": "string" } },
              "body": { "type": "object" },
              "expected_status": { "type": "integer" },
              "expected_body": { "type": "object" },
              "description": { "type": "string" }
            }
          }
        },
        "playwright_checks": {
          "type": "array",
          "description": "Browser-level UI flow verifications",
          "items": {
            "type": "object",
            "required": ["id", "description", "steps"],
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" },
              "url": { "type": "string" },
              "steps": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["action"],
                  "properties": {
                    "action": { "type": "string" },
                    "selector": { "type": "string" },
                    "value": { "type": "string" },
                    "assertion": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "design_checks": {
          "type": "object",
          "description": "Visual/UX criteria evaluated against the scoring rubric. Keys map 1:1 onto the design-critic's eval-scores.json output; each key's min_score is the per-criterion floor the critic's score must meet.",
          "properties": {
            "design_quality": {
              "type": "object",
              "properties": {
                "required": { "type": "boolean" },
                "min_score": { "type": "integer", "minimum": 1, "maximum": 10 }
              }
            },
            "originality": {
              "type": "object",
              "properties": {
                "required": { "type": "boolean" },
                "min_score": { "type": "integer", "minimum": 1, "maximum": 10 }
              }
            },
            "craft": {
              "type": "object",
              "properties": {
                "required": { "type": "boolean" },
                "min_score": { "type": "integer", "minimum": 1, "maximum": 10 }
              }
            },
            "functionality": {
              "type": "object",
              "properties": {
                "required": { "type": "boolean" },
                "min_score": { "type": "integer", "minimum": 1, "maximum": 10 }
              }
            }
          }
        },
        "performance_checks": {
          "type": "array",
          "description": "Per-endpoint latency overrides. GET endpoints are ratcheted against a recorded p95 baseline (regression = FAIL); non-GET endpoints get a single-shot budget WARN. Omitted budgets fall back to project-manifest.json execution.latency_budget_ms (read/write).",
          "items": {
            "type": "object",
            "properties": {
              "endpoint": { "type": "string" },
              "max_response_time_ms": { "type": "number", "description": "Absolute budget (advisory WARN) for this endpoint, overriding the manifest default." },
              "method": { "type": "string", "default": "GET" },
              "regression_threshold_pct": { "type": "number", "description": "Per-endpoint p95 regression threshold for the ratchet, overriding execution.latency_budget_ms.regression_pct (default 50)." }
            }
          }
        },
        "architecture_checks": {
          "type": "object",
          "description": "Structural code quality checks",
          "properties": {
            "files_must_exist": {
              "type": "array",
              "description": "File paths (relative to project root) that must be present on disk. The evaluator FAILs the architecture gate if any listed path is absent. Populate from the story's component-map entries when proposing the sprint contract.",
              "items": { "type": "string" }
            },
            "layering": {
              "type": "object",
              "properties": {
                "required": { "type": "boolean" },
                "description": { "type": "string" }
              }
            },
            "typing": {
              "type": "object",
              "properties": {
                "required": { "type": "boolean" },
                "description": { "type": "string" }
              }
            },
            "folder_structure": {
              "type": "object",
              "properties": {
                "required": { "type": "boolean" },
                "description": { "type": "string" }
              }
            },
            "env_vars": {
              "type": "object",
              "properties": {
                "required": { "type": "boolean" },
                "description": { "type": "string" }
              }
            },
            "migrations": {
              "type": "object",
              "properties": {
                "required": { "type": "boolean" },
                "description": { "type": "string" }
              }
            }
          }
        },
        "productivity_budget": {
          "type": "object",
          "description": "Harness-specific effort caps for the group. Token/cost budgets live in native OTEL metrics, not here.",
          "properties": {
            "max_iterations": { "type": "integer", "minimum": 1 },
            "max_files_changed": { "type": "integer", "minimum": 1 },
            "_note": { "type": "string" }
          }
        },
        "security_checks": {
          "type": "object",
          "description": "Security gate. The validator FAILs if the security-reviewer reports any finding at or above a blocking severity. Enforced by /evaluate and the /auto loop via specs/reviews/security-verdict.json.",
          "properties": {
            "required": {
              "type": "boolean",
              "default": true,
              "description": "When true (default), the overall evaluation verdict requires security-verdict.json#pass === true."
            },
            "block_severities": {
              "type": "array",
              "description": "Severities that fail the gate. Default: critical and high.",
              "items": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
              "default": ["critical", "high"]
            }
          }
        }
      }
    }
  }
}
