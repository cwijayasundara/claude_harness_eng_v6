  "rule": "A kernel unit may not hard-reference a pack unit. Enforced by tools/check-partition.js --strict.",
  "resolution_policy": {
    "move-callee-to-kernel": "the callee is infrastructure the kernel genuinely needs",
    "move-caller-to-pack": "the caller is pack content that was mis-homed",
    "make-optional": "the call degrades cleanly when the pack is absent (try/catch + skip, reported not silent)"
  },
  "accepted_edges": [
    {
      "from": "skill:refactor",
      "to": "skill:code-map",
      "why": "Caller lookup for rename/move blast radius. The whole block is already conditional on specs/brownfield/code-graph.json existing, which only happens when the brownfield pack is installed — /refactor works without it. Prose conditionality the checker cannot see."
    }
  ],
