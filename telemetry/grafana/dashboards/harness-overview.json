      "targets": [{
        "expr": "sum by (story) (max_over_time(harness_conversation_turns_total{job=\"claude_harness_memory\",user=~\"$user\", lane=~\"$lane\", group=~\"$group\"}[$__range]))",
        "legendFormat": "{{story}}",
