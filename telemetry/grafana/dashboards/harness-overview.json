{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "row",
      "title": "Velocity Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Team Activity — Turns by User",
      "description": "Total cumulative conversation turns per team member. Moves for slash commands even before agent runs exist.",
      "type": "barchart",
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus" },
      "targets": [{
        "expr": "sum by (user) (max_over_time(harness_conversation_turns_total{job=\"claude_harness_memory\",user=~\"$user\", lane=~\"$lane\", group=~\"$group\"}[$__range]))",
        "legendFormat": "{{user}}",
        "instant": true
      }],
      "options": {
        "orientation": "vertical",
        "showValue": "always",
        "barWidth": 0.6,
        "groupWidth": 0.8,
        "stacking": "none",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      }
    },
    {
      "title": "Quality — Success vs Failure",
      "description": "Overall success rate. Uses agent runs when present; otherwise falls back to tool completion results.",
      "type": "piechart",
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus" },
      "targets": [{
        "expr": "sum by (exit) (max_over_time(harness_agent_runs_total{job=\"claude_harness_memory\",kind=~\"subagent|subagent_stop\", user=~\"$user\", lane=~\"$lane\", group=~\"$group\"}[$__range])) or sum by (exit) (max_over_time(harness_tool_events_total{job=\"claude_harness_memory\",user=~\"$user\", lane=~\"$lane\", group=~\"$group\"}[$__range]))",
        "legendFormat": "{{exit}}"
      }],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "values": ["value", "percent"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "ok" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "type": "row",
      "title": "Workload Distribution",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 },
      "collapsed": false
    },
    {
      "title": "Agent / Tool Workload — Runs by Type",
      "description": "Runs per agent type when subagent telemetry exists; otherwise falls back to tool activity.",
      "type": "barchart",
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 11 },
      "datasource": { "type": "prometheus" },
      "targets": [{
        "expr": "sum by (agent) (max_over_time(harness_agent_runs_total{job=\"claude_harness_memory\",kind=~\"subagent|subagent_stop\", user=~\"$user\", lane=~\"$lane\", group=~\"$group\"}[$__range])) or sum by (agent) (label_replace(max_over_time(harness_tool_events_total{job=\"claude_harness_memory\",user=~\"$user\", lane=~\"$lane\", group=~\"$group\"}[$__range]), \"agent\", \"tool:$1\", \"tool\", \"(.+)\"))",
        "legendFormat": "{{agent}}",
        "instant": true
      }],
      "options": {
        "orientation": "vertical",
        "showValue": "always",
        "barWidth": 0.6,
        "groupWidth": 0.8,
        "stacking": "none",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      }
    },
    {
      "title": "Lane Usage",
      "description": "Work distribution by lane. Uses cumulative conversation turns so BRD/spec/design activity appears immediately.",
      "type": "piechart",
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 11 },
      "datasource": { "type": "prometheus" },
      "targets": [{
        "expr": "sum by (lane) (max_over_time(harness_conversation_turns_total{job=\"claude_harness_memory\",user=~\"$user\", lane=~\"$lane\", group=~\"$group\"}[$__range]))",
        "legendFormat": "{{lane}}"
      }],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "values": ["value", "percent"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] }
    },
    {
      "type": "row",
      "title": "Sprint Progress",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "collapsed": false
    },
    {
      "title": "Current Iteration per Group",
      "description": "Ratchet iterations per dependency group. Fewer = more efficient.",
      "type": "stat",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus" },
      "targets": [{
        "expr": "max by (group, user) (harness_iteration_current{job=\"claude_harness_memory\",user=~\"$user\", group=~\"$group\"})",
        "legendFormat": "{{group}} ({{user}})"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color":"green","value":null},{"color":"yellow","value":5},{"color":"red","value":10}] } }, "overrides": [] }
    },
    {
      "title": "Active Stories",
      "description": "Stories currently being worked on, by user and group.",
      "type": "table",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 21 },
      "datasource": { "type": "prometheus" },
      "targets": [{
        "expr": "harness_story_active{job=\"claude_harness_memory\",user=~\"$user\", group=~\"$group\"}",
        "format": "table",
        "instant": true
      }],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true, "Value": true } } }
      ]
    },
    {
      "title": "Pending Reviews",
      "description": "Reviews waiting for humans. Rising = harness outpacing reviewers.",
      "type": "stat",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 21 },
      "datasource": { "type": "prometheus" },
      "targets": [{
        "expr": "sum by (user) (harness_pending_reviews{job=\"claude_harness_memory\",user=~\"$user\"})",
        "legendFormat": "{{user}}"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color":"green","value":null},{"color":"yellow","value":3},{"color":"red","value":5}] } }, "overrides": [] }
    },
    {
      "type": "row",
