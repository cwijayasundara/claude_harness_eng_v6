{
  "title": "Claude Harness — Prompt Cache Health",
  "tags": ["claude-code", "prompt-cache", "harness"],
  "refresh": "30s",
  "panels": [
    {
      "title": "Cache Hit Rate (fleet, 5m)",
      "targets": [
        {
          "expr": "claude_code:cache_hit_rate:ratio_rate5m",
          "legendFormat": "fleet"
        }
      ],
      "type": "stat",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.4 },
              { "color": "green", "value": 0.7 }
            ]
          }
        }
      }
    },
    {
      "title": "Cache Hit Rate over time (by model)",
      "targets": [
        {
          "expr": "claude_code:cache_hit_rate:ratio_rate5m",
          "legendFormat": "fleet"
        },
        {
          "expr": "claude_code:cache_hit_rate:ratio_rate5m_by_model",
          "legendFormat": "{{ model }}"
        }
      ],
      "type": "timeseries",
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } }
    },
    {
      "title": "Input token mix (rate, by type)",
      "targets": [
        {
          "expr": "sum by (type) (rate(claude_code_token_usage_tokens_total{type=~\"input|cacheRead|cacheCreation\"}[5m]))",
          "legendFormat": "{{ type }}"
        }
      ],
      "type": "timeseries"
    },
    {
      "title": "Cache-creation token rate (prefix rebuilds — spikes = cache breaks)",
      "targets": [
        {
          "expr": "sum by (model) (rate(claude_code_token_usage_tokens_total{type=\"cacheCreation\"}[5m]))",
          "legendFormat": "{{ model }}"
        }
      ],
      "type": "timeseries"
    }
  ]
}
