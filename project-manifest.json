{
  "name": "claude-harness-eng-v5",
  "description": "Claude Harness Engine — plugin monorepo (dogfood / Project Zero)",
  "topology": "cli-or-library",
  "stack": {
    "backend": { "language": "javascript", "framework": "node" },
    "frontend": null,
    "database": null
  },
  "architecture": {
    "enabled": false
  },
  "observability": {
    "enabled": true,
    "metrics_path": "/metrics",
    "red_labels": ["method", "route", "status"],
    "slo": {
      "error_rate_pct": 1,
      "p95_ms": 500
    },
    "note": "Project Zero dogfood: convention flag for harness telemetry/metrics docs. The harness monorepo is not a product server; generators still follow G9 when scaffolding product apps."
  },
  "verification": {
    "mode": "local"
  },
  "execution": {
    "default_mode": "full",
    "model_tier": "balanced",
    "ceremony": "trimmed",
    "coverage_threshold": 80
  },
  "quality": {
    "sensor_tier": "standard",
    "agent_readiness": {
      "mode": "ratchet",
      "min_active_pillars": 5,
      "forbid_regression": true
    }
  },
  "token_governor": {
    "enabled": true,
    "mode": "advisory",
    "living_navigation": true,
    "context_search_required": true,
    "max_source_read_lines": 300,
    "tool_output_token_estimates": true,
    "compress_tool_output": true,
    "ccr_enabled": true,
    "preserve_full_outputs": true,
    "budget_warn_pct": 80
  },
  "evaluation": {
    "api_base_url": null,
    "ui_base_url": null,
    "health_check": null
  }
}
